# Site URL for SEO (canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://deltaplanai.example.com

# Временно: только эти email могут регистрироваться и входить (через запятую, lowercase)
NEXT_PUBLIC_AUTH_ALLOWED_EMAILS=ruslansusla93@gmail.com

# Supabase (public anon key only — safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Yandex OAuth — НЕ OIDC. Только Manual / OAuth2 в Supabase Dashboard.
#
# 1) oauth.yandex.ru → ваше приложение → платформа «Веб-сервисы»
#    Callback URL (обязательно, иначе 403):
#      https://<project-ref>.supabase.co/auth/v1/callback
#    Доступ к данным (обязательно, иначе invalid_scope):
#      ✓ Адрес электронной почты          → login:email
#      ✓ Логин, имя и фамилия, пол        → login:info
#    Проверка: https://oauth.yandex.ru/client/<client_id>/info
#    Scopes в Supabase должны совпадать с разрешениями приложения.
#
# 2) Supabase → Auth → Custom Providers → Manual (OAuth2), identifier: custom:yandex
#    userinfo_url: https://login.yandex.ru/info?format=json
#    scopes: login:email, login:info
#    email_optional: true  ← обязательно (Яндекс отдаёт default_email, не email)
#    custom_claims_allowlist: default_email, display_name, login, ...
#    authorization_params: force_confirm=yes
#    Ошибка "Error getting user email from external provider" → scripts/update-yandex-oauth.ps1
#
# 3) Supabase → Auth → URL Configuration → Redirect URLs:
#    https://ваш-домен/auth/callback
#    http://localhost:3000/auth/callback
#
# Скрипты: scripts/setup-yandex-oauth.ps1 | scripts/update-yandex-oauth.ps1

# Do NOT expose SUPABASE_SERVICE_ROLE_KEY to the client.
# Server-only (Vercel): webhook ЮKassa — начисление Deai и смена тарифа.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ЮKassa — оплата тарифов Base / Pro для пользователей из РФ
# 1) yookassa.ru → Интеграция → shopId + секретный ключ
# 2) HTTP-уведомления → URL:
#      https://ваш-домен/api/payments/yookassa/webhook
#    События: payment.succeeded, payment.canceled
# 3) Vercel → Environment Variables (Production):
#      YOOKASSA_SHOP_ID=...
#      YOOKASSA_SECRET_KEY=...
#      SUPABASE_SERVICE_ROLE_KEY=...
# 4) Supabase SQL Editor → supabase/migration-yookassa-payments.sql
# Тестовый магазин: те же переменные с ключами из личного кабинета ЮKassa (режим тест)
YOOKASSA_SHOP_ID=your-yookassa-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret-key

# OpenAI — ChatGPT (только сервер)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic — Claude (только сервер)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Runway — генерация видео (только сервер)
# 1) https://dev.runwayml.com/ → Manage → New API key (один ключ, начинается с key_)
# 2) Billing → добавьте credits (отдельно от app.runwayml.com)
# 3) Проверка: scripts\run-runway-check.cmd
RUNWAY_API_KEY=your-runway-api-key

# Google — Veo, Nano Banana (только сервер)
GOOGLE_API_KEY=your-google-ai-api-key
# или GEMINI_API_KEY=your-gemini-api-key

# xAI — Grok (чат), Grok Imagine (изображения), Grok Video (видео) — один ключ XAI_API_KEY
# Ключ: https://console.x.ai/ → API Keys + Billing
# Чат: grok-4.3 · scripts\run-xai-chat-check.cmd
# Imagine: grok-imagine-image · scripts\run-xai-imagine-check.cmd
# Video: grok-imagine-video · POST /v1/videos/generations
XAI_API_KEY=your-xai-api-key

# Black Forest Labs — FLUX (только сервер)
BFL_API_KEY=your-bfl-api-key
# Ключ и кредиты: https://api.bfl.ai
# опционально: BFL_API_BASE=https://api.eu.bfl.ai/v1

# Kling AI — видео (только сервер)
# 1) https://app.klingai.com/global/dev/api-key → Create a new API Key
# 2) Скопируйте ключ из окна → KLING_API_KEY (достаточно для Vercel, если один ключ)
#    Если 401: добавьте KLING_ACCESS_KEY из таблицы (колонка «API Key») +
#    KLING_API_KEY или KLING_SECRET_KEY из окна Create.
#    Либо одной строкой: KLING_API_KEY=access:secret
# 3) Проверка: scripts\run-kling-check.cmd
KLING_API_KEY=your-kling-api-key
# KLING_ACCESS_KEY=your-kling-access-key-from-table
# KLING_SECRET_KEY=your-kling-secret-key-from-popup
# Регион API (по умолчанию Singapore; если ошибки сети — попробуйте api.klingai.com):
# KLING_API_BASE=https://api-singapore.klingai.com
# KLING_API_BASE=https://api.klingai.com
