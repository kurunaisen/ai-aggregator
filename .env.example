# Site URL for SEO (canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://deltaplanai.example.com

# Supabase (public anon key only — safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Yandex OAuth — НЕ OIDC. Только Manual / OAuth2 в Supabase Dashboard.
# Ошибка "OIDC discovery from oauth.yandex.ru/authorize/.well-known..." =
#   выбран Auto-discovery (OIDC) вместо Manual (OAuth2).
#
# Dashboard: Auth → Custom Providers → New → Manual configuration (OAuth2)
#   identifier: custom:yandex
#   authorization_url: https://oauth.yandex.ru/authorize
#   token_url:         https://oauth.yandex.ru/token
#   userinfo_url:      https://login.yandex.ru/info?format=json
#   scopes: login:email, login:info
#
# Yandex OAuth redirect URI: https://<project>.supabase.co/auth/v1/callback
# Или скрипт: scripts/setup-yandex-oauth.ps1 (нужен SUPABASE_SERVICE_ROLE_KEY)

# Do NOT add SUPABASE_SERVICE_ROLE_KEY to this project.
# Admin operations belong in Supabase Dashboard or Edge Functions.

# OpenAI — ChatGPT (только сервер)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic — Claude (только сервер)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Runway — генерация видео (только сервер)
RUNWAY_API_KEY=your-runway-api-key

# Google — Veo, Nano Banana (только сервер)
GOOGLE_API_KEY=your-google-ai-api-key
# или GEMINI_API_KEY=your-gemini-api-key

# xAI — Grok (чат) и Grok Imagine (изображения, тот же ключ)
XAI_API_KEY=your-xai-api-key

# Black Forest Labs — FLUX (только сервер)
BFL_API_KEY=your-bfl-api-key
# Ключ и кредиты: https://api.bfl.ai
# опционально: BFL_API_BASE=https://api.eu.bfl.ai/v1

# Kling AI — видео (только сервер)
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key
# опционально: KLING_API_BASE=https://api-singapore.klingai.com
